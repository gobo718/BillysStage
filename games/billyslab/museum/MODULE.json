{
  "$schema": "../../../contracts/module-manifest.schema.json",
  "id": "museum",
  "name": "BillysLab Museum",
  "version": "0.2.0",
  "status": "foundation",
  "purpose": "Public player-facing experience for browsing, learning, collecting, and progressing.",
  "owns": [
    "home-ui",
    "mashup-viewer-ui",
    "laboratory-ui",
    "collection-ui",
    "profile-ui",
    "trophy-room-ui",
    "daily-pick-ui",
    "public-navigation",
    "public-action-ui"
  ],
  "dependsOn": [
    "engine",
    "billyslab-content"
  ],
  "mayImport": [
    "engine.public",
    "billyslab-content.public"
  ],
  "mustNotImport": [
    "curator.private",
    "curator.drafts"
  ],
  "exports": [
    "public-routes",
    "player-ui-events"
  ],
  "currentEvidence": [
    "index.html",
    "mashup.html",
    "collection-book.html",
    "collection.html",
    "emoji.html",
    "profile.html",
    "blurblets.html",
    "dispatches.html",
    "studio.html",
    "trophy-room.html",
    "bottom-nav.js",
    "action-ui.js",
    "profile.js",
    "profile.css",
    "billyisms.js",
    "achievements.js",
    "hidden-categories.js"
  ],
  "migrationDebt": [
    "explorer.html contains Curator/archive responsibility",
    "mashup.html contains editing/development responsibility",
    "Museum currently consumes curator-data.js"
  ]
}
